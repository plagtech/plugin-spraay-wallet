{
  "name": "@elizaos/plugin-spraay-wallet",
  "version": "1.0.0",
  "description": "💧 Spraay Agent Wallet plugin for ElizaOS — provision smart wallets, manage session keys, and predict wallet addresses via x402 micropayments on Base",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/ --ext .ts",
    "test": "vitest run"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "EVM_PRIVATE_KEY": {
        "type": "string",
        "description": "EVM private key for signing x402 payments to the Spraay gateway"
      },
      "SPRAAY_GATEWAY_URL": {
        "type": "string",
        "description": "Spraay gateway URL (default: https://gateway.spraay.app)"
      }
    }
  },
  "keywords": [
    "elizaos",
    "elizaos-plugins",
    "spraay",
    "agent-wallet",
    "x402",
    "base",
    "batch-payments",
    "session-keys",
    "smart-wallet",
    "usdc"
  ],
  "author": "plagtech",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/plagtech/plugin-spraay-wallet"
  },
  "peerDependencies": {
    "@elizaos/core": "^1.0.0"
  },
  "dependencies": {
    "ethers": "^6.13.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@elizaos/core": "^1.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "eslint": "^8.56.0"
  }
}
